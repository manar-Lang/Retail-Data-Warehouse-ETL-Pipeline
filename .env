# ============================================
# PostgreSQL Airflow Database Configuration
# ============================================
POSTGRES_AIRFLOW_PORT=5432
POSTGRES_AIRFLOW_USER=airflow
POSTGRES_AIRFLOW_PASSWORD=airflow
POSTGRES_AIRFLOW_DB=airflow
POSTGRES_AIRFLOW_VOLUME=./postgres-airflow/data

# ============================================
# PostgreSQL Application Database Configuration
# ============================================
POSTGRES_APP_PORT=5433
POSTGRES_APP_USER=app_user
POSTGRES_APP_PASSWORD=app_password
POSTGRES_APP_DB=app_data
POSTGRES_APP_VOLUME=./postgres-app/data

# ============================================
# SQL Scripts Location Locally
# ============================================
SQL_SCRIPTS_VOLUME=./sql_scripts


# ============================================
# Common Python Packages for ALL environments
# ============================================
COMMON_PYTHON_PACKAGES=confluent-kafka==2.3.0 fastapi==0.104.1 uvicorn==0.24.0 pyarrow==10.0.1 streamlit==1.28.0 plotly==5.18.0 dash==2.14.0 pytest==7.4.0

# ============================================
# Redis Configuration
# ============================================
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ============================================
# Airflow Configuration
# ============================================
AIRFLOW_IMAGE=apache/airflow:2.7.3-python3.11
AIRFLOW_CORE_EXECUTOR=CeleryExecutor
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=
AIRFLOW_SECRET_KEY=mysecretkey
AIRFLOW_LOAD_EXAMPLES=False
AIRFLOW_ENABLE_XCOM_PICKLING=True

# Airflow Database Connection Strings
AIRFLOW_SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres-airflow:5432/airflow
AIRFLOW_CELERY_RESULT_BACKEND=db+postgresql://airflow:airflow@postgres-airflow:5432/airflow

# Airflow Additional PIP Packages
AIRFLOW_EXTRA_PIP_PACKAGES=apache-airflow-providers-apache-spark==4.1.1 apache-airflow-providers-apache-kafka==1.5.0 pandas==2.0.3 confluent-kafka==2.3.0 fastapi==0.104.1 uvicorn==0.24.0 pyarrow==10.0.1 streamlit==1.28.0 plotly==5.18.0 dash==2.14.0 pytest==7.4.0 pyspark==3.4.1 scikit-learn==1.3.2

# ============================================
# Airflow Volume Paths
# ============================================
AIRFLOW_DAGS_VOLUME=./airflow/dags
AIRFLOW_LOGS_VOLUME=./airflow/logs
AIRFLOW_PLUGINS_VOLUME=./airflow/plugins
AIRFLOW_SCRIPTS_VOLUME=./airflow/scripts
# SPARK_JOBS_VOLUME=./spark_jobs

# ============================================
# pgAdmin Configuration
# ============================================
PGADMIN_IMAGE=dpage/pgadmin4:7
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
PGADMIN_VOLUME=./pgadmin

# ============================================
# Kafka Configuration
# ============================================
KAFKA_IMAGE=confluentinc/cp-kafka:7.6.1
KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=29092
KAFKA_CONTROLLER_PORT=29093
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# ============================================
# Schema Registry Configuration
# ============================================
SCHEMA_REGISTRY_IMAGE=confluentinc/cp-schema-registry:7.6.1
SCHEMA_REGISTRY_PORT=8081

# ============================================
# Kafka UI Configuration
# ============================================
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:latest
KAFKA_UI_PORT=8090

# ============================================
# Development Environment Configuration
# ============================================
DEV_IMAGE=jupyter/pyspark-notebook:spark-3.4.1
DEV_CODE_VOLUME=./dev_code
JUPYTER_PORT=8888
SPARK_UI_PORT=4040
JUPYTER_TOKEN=devtoken
CHECKPOINT_VOLUME=./checkpoint
